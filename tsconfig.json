{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "stripInternal": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "composite": false
  },
  "files": [],
  "references": [
    { "path": "./packages/pixi-reels" },
    { "path": "./examples/classic-spin" },
    { "path": "./examples/cascade-tumble" },
    { "path": "./examples/big-symbols" },
    { "path": "./examples/multiways" },
    { "path": "./examples/pyramid-cascade" },
    { "path": "./examples/sandbox" },
    { "path": "./apps/site" }
  ]
}
