# Copy to .env for local dev. Defaults boot the server with in-memory
# storage on :8787 — fine for the studio dev loop, useless for anything
# you care about (everything is lost on restart).

# Listening port.
PORT=8787

# Where the docs-site viewer lives. The API bakes this into the share
# URL it returns from POST /api/studios. In dev that's localhost:4321
# (Astro's default port). In prod, pixi-reels.schmooky.dev.
VIEWER_BASE_URL=http://localhost:4321

# Comma-separated allow-list of CORS origins. Dev: the local Astro port.
# Prod: set to the deployed docs-site origin (e.g.
# https://pixi-reels.schmooky.dev). Avoid '*' in production.
CORS_ORIGIN=http://localhost:4321

# Per-IP cap for POST /api/studios — keep generous for dev, tighter in prod.
CREATE_RATE_LIMIT_PER_MIN=20

# Bearer required on POST /api/cleanup. Empty = endpoint is disabled.
CLEANUP_BEARER=

# Storage backend: 'memory' (in-process) or 's3' (real bucket).
STORAGE=memory

# S3-compatible store (ignored when STORAGE=memory). Mirror the
# spine-benchmark schmooky.dev defaults for production deployment.
S3_REGION=ru-1
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
