{
  "name": "@pixi-reels/site",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-assets": "node -e \"const fs=require('fs');fs.cpSync('../../examples/assets/prototype-symbols','public/prototype-symbols',{recursive:true});fs.mkdirSync('src/generated',{recursive:true});fs.copyFileSync('../../packages/pixi-reels/CHANGELOG.md','src/generated/CHANGELOG.md');\"",
    "llms:gen": "node scripts/build-llms.mjs",
    "api:gen": "typedoc && node scripts/postprocess-api.mjs",
    "api:check-sync": "node scripts/check-api-sync.mjs",
    "og:render": "node scripts/render-og.mjs",
    "predev": "pnpm sync-assets && pnpm llms:gen && pnpm api:gen && pnpm og:render",
    "prebuild": "pnpm sync-assets && pnpm llms:gen && pnpm api:gen && pnpm og:render",
    "prepreview": "pnpm sync-assets && pnpm llms:gen && pnpm api:gen && pnpm og:render",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.7",
    "@esotericsoftware/spine-pixi-v8": "~4.2.110",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.15.0",
    "pixi-reels": "workspace:*",
    "pixi.js": "^8.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  }
}
