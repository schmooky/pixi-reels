---
import Base from '../../layouts/Base.astro';
import {
  FAQ,
  FAQ_ANSWERED,
  FAQ_GROUP_TITLE,
  type FaqQuestionResolved,
} from '../../content/faq.ts';
import { ChevronLeft, Check, ArrowRight } from 'lucide-react';
import { SITE, qaPageLd, articleLd, breadcrumbLd } from '../../lib/seo.ts';

// One page per ANSWERED question. Adding an answer in faq.ts mints a page
// here automatically; open questions stay on the index until answered.
export function getStaticPaths() {
  return FAQ_ANSWERED.map((q) => ({ params: { id: q.id }, props: { q } }));
}

interface Props {
  q: FaqQuestionResolved;
}
const { q } = Astro.props as Props;
const groupTitle = FAQ_GROUP_TITLE[q.group];
const path = `/faq/${q.id}/`;

const escapeHtml = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
// Plain prose → HTML: blank lines split paragraphs, `code` spans become <code>.
function renderAnswer(text: string): string {
  return text
    .split(/\n\n+/)
    .map((p) => {
      const html = escapeHtml(p).replace(
        /`([^`]+)`/g,
        '<code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.85em]">$1</code>',
      );
      return `<p class="leading-7 text-foreground/85">${html}</p>`;
    })
    .join('');
}
const plain = (s: string) => s.replace(/`/g, '');

const answerEn = q.answer!.en;
const description = plain(answerEn).slice(0, 155);

// Related: other questions in the same group (answered first, then open).
const related: FaqQuestionResolved[] = (FAQ.find((g) => g.id === q.group)?.questions ?? [])
  .map((x) => ({ ...x, group: q.group }))
  .filter((x) => x.id !== q.id)
  .sort((a, b) => Number(!!b.answer) - Number(!!a.answer))
  .slice(0, 8);

const editUrl = `${SITE.githubRepo}/edit/main/apps/site/src/content/faq.ts`;
---
<Base
  title={`${q.en} · ${SITE.name} FAQ`}
  description={description}
  path={path}
  type="article"
  article={{ section: 'FAQ', tags: [q.group] }}
  jsonLd={[
    qaPageLd({ question: q.en, answer: plain(answerEn), path }),
    articleLd({ title: q.en, description, path }),
    breadcrumbLd([
      { name: SITE.name, url: '/' },
      { name: 'FAQ', url: '/faq/' },
      { name: groupTitle.en, url: `/faq/#${q.group}` },
      { name: q.en, url: path },
    ]),
  ]}
>
  <div class="container max-w-[760px] py-10 animate-fade-in">
    <header class="mb-6">
      <a href="/faq/" class="mb-4 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">
        <ChevronLeft size={14} strokeWidth={2} />
        All questions
      </a>
      <div class="mb-3 flex items-center gap-2 text-xs">
        <span class="inline-flex items-center gap-1 rounded-full bg-primary/10 px-2.5 py-0.5 font-medium text-primary">
          <Check size={11} strokeWidth={3} /> Answered
        </span>
        <a href={`/faq/#${q.group}`} class="rounded-full border border-border px-2.5 py-0.5 text-muted-foreground hover:text-foreground transition-colors">
          {groupTitle.en}
        </a>
      </div>
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">{q.en}</h1>
    </header>

    <article class="space-y-4">
      <div class="space-y-3" set:html={renderAnswer(answerEn)} />

      {q.links && q.links.length > 0 && (
        <div class="not-prose rounded-xl border border-border bg-card p-4">
          <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">See it work</div>
          <ul class="space-y-1.5">
            {q.links.map((l) => (
              <li>
                <a href={l.href} class="group inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline">
                  {l.label}
                  <ArrowRight size={13} strokeWidth={2} className="transition-transform group-hover:translate-x-0.5" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </article>

    {related.length > 0 && (
      <section class="mt-10 border-t border-border/60 pt-6">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
          More in {groupTitle.en}
        </h2>
        <ul class="divide-y divide-border/60 overflow-hidden rounded-xl border border-border bg-card">
          {related.map((r) => {
            const answered = !!r.answer;
            const href = answered ? `/faq/${r.id}/` : `/faq/#${r.id}`;
            return (
              <li>
                <a href={href} class="group flex items-center gap-3 px-4 py-2.5 text-sm transition-colors hover:bg-secondary/30">
                  <span
                    class:list={[
                      'flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-[9px] font-bold',
                      answered ? 'bg-primary/15 text-primary' : 'border border-border text-muted-foreground/50',
                    ]}
                  >
                    {answered ? <Check size={10} strokeWidth={3} /> : '?'}
                  </span>
                  <span class="min-w-0 flex-1 truncate text-foreground/80">{r.en}</span>
                  {!answered && <span class="shrink-0 text-[10px] uppercase tracking-wide text-muted-foreground/50">open</span>}
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    <footer class="mt-8 text-xs text-muted-foreground">
      Spotted a better answer? <a href={editUrl} class="text-primary hover:underline">Improve this on GitHub →</a>
    </footer>
  </div>
</Base>
