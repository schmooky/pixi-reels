---
import Base from '../../layouts/Base.astro';
import Studio from '../../components/Studio.tsx';
---
<Base
  title="Studio · pixi-reels"
  description="Live workbench for pixi-reels. Write TypeScript and watch reels rebuild — recipes open here, the prototype atlas is preloaded, and you can drop in your own sprites, animated sheets, or Spine bundles in the Symbols tab."
>
  <section class="border-b border-border/60 py-10">
    <div class="container max-w-3xl text-center">
      <div class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary">
        Workbench
      </div>
      <h1 class="mt-4 text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
        Edit. Wire. <span class="gradient-text">Spin.</span>
      </h1>
      <p class="mx-auto mt-3 max-w-xl text-sm text-muted-foreground">
        Write TypeScript in the <strong>Code</strong> tab — the prototype atlas, <code class="rounded bg-secondary/70 px-1.5 py-0.5 font-mono text-[11px]">CardSymbol</code>, and every recipe global are preloaded. Bring your own sprites, animated sheets, or Spine bundles via the <strong>Symbols</strong> tab. Everything persists locally; your assets never leave the browser.
      </p>
    </div>
  </section>

  <section class="py-6 pb-14">
    <div class="container">
      <Studio client:only="react" />
    </div>
  </section>
</Base>
