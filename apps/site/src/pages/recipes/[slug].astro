---
import { getCollection, render } from 'astro:content';
import Recipe from '../../layouts/Recipe.astro';
import RecipeDemo from '../../components/RecipeDemo.astro';
import RecipeImage from '../../components/RecipeImage.astro';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, steps, apis, tags } = entry.data;
---
<Recipe title={title} description={description} steps={steps} apis={apis} tags={tags}>
  <Content components={{ RecipeDemo, Image: RecipeImage }} />
</Recipe>
