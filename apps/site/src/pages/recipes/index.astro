---
import Base from '../../layouts/Base.astro';
import { RECIPES, RECIPE_GROUPS } from '../../content/recipes.ts';
import { ArrowRight } from 'lucide-react';
import { breadcrumbLd, articleLd, SITE } from '../../lib/seo.ts';

const title = 'Recipes. mini pixi-reels how-tos';
const description = 'Focused, single-idea recipes for slot mechanics built with pixi-reels: how to remove a symbol in a cascade, anticipate a reel, expand a wild, animate paylines, slam-stop, and fake a near-miss.';

// Group recipes by their `group` field; preserve declaration order within each group.
const recipesByGroup = new Map<string, typeof RECIPES>();
for (const recipe of RECIPES) {
  const list = recipesByGroup.get(recipe.group) ?? [];
  list.push(recipe);
  recipesByGroup.set(recipe.group, list);
}
---
<Base
  title={`Recipes · ${SITE.name}`}
  description={description}
  path="/recipes/"
  jsonLd={[
    articleLd({ title, description, path: '/recipes/' }),
    breadcrumbLd([
      { name: SITE.name, url: '/' },
      { name: 'Recipes', url: '/recipes/' },
    ]),
  ]}
>
  <section class="border-b border-border/60 py-16">
    <div class="container max-w-3xl text-center">
      <div class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary">
        Cookbook
      </div>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
        Small recipes, <span class="gradient-text">one mechanic each.</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-muted-foreground">
        Each page is a focused how-to: the minimum code to make a single
        mechanic work, plus a live mini-demo you can replay.
      </p>
    </div>
  </section>

  <nav aria-label="Recipe groups" class="sticky top-0 z-30 border-b border-border/60 bg-background/85 backdrop-blur">
    <div class="container flex flex-wrap items-center gap-2 py-3">
      {RECIPE_GROUPS.map((g) => {
        const groupRecipes = recipesByGroup.get(g.id) ?? [];
        if (groupRecipes.length === 0) return null;
        return (
          <a
            href={`#${g.id}`}
            class="inline-flex items-center rounded-full border border-border/70 bg-card/60 px-3 py-1 text-xs font-medium text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground"
          >
            {g.label}
          </a>
        );
      })}
    </div>
  </nav>

  <section class="py-14">
    <div class="container space-y-14">
      {RECIPE_GROUPS.map((g) => {
        const groupRecipes = recipesByGroup.get(g.id) ?? [];
        if (groupRecipes.length === 0) return null;
        return (
          <div id={g.id} class="scroll-mt-20">
            <div class="mb-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground/80">
              {g.label}
            </div>
            <p class="mb-5 text-sm text-muted-foreground/80">{g.description}</p>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {groupRecipes.map((r) => (
                <a
                  href={`/recipes/${r.slug}/`}
                  class="group flex flex-col rounded-xl border border-border bg-card p-5 transition-all hover:border-primary/40 hover:-translate-y-0.5"
                >
                  <h3 class="text-base font-semibold tracking-tight">{r.title}</h3>
                  <p class="mt-2 text-sm text-muted-foreground">{r.oneLiner}</p>
                  <div class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-foreground/60 transition-colors group-hover:text-foreground">
                    Open recipe <ArrowRight size={13} strokeWidth={2} />
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Base>
