          <text x="280" y="280" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(var(--muted-foreground))">named profiles</text>
        </g>
        <g>
          <rect x="360" y="240" width="150" height="56" rx="10" fill="hsl(var(--card))" stroke="hsl(var(--border-strong))" stroke-width="1.5" />
