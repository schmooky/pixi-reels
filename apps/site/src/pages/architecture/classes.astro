        <text x="480" y="455" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(var(--muted-foreground))">one reel contains:</text>

        <rect x="60" y="470" width="800" height="220" rx="14" fill="hsl(var(--muted))" fill-opacity="0.5" stroke="hsl(var(--border))" stroke-width="1" />
