          <text x="750" y="280" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(var(--muted-foreground))">middleware pipeline</text>
        </g>

        <!-- Reels[] -->
        <path d="M 460 200 L 460 340" stroke="hsl(var(--primary))" stroke-width="2" fill="none" />
        <rect x="280" y="340" width="360" height="90" rx="14" fill="hsl(var(--accent))" fill-opacity="0.08" stroke="hsl(var(--accent))" stroke-dasharray="5 4" stroke-width="1.5" />
        <text x="295" y="362" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="700" fill="hsl(var(--accent))" letter-spacing="0.08em">REELS[]</text>

        <g transform="translate(295, 372)">
