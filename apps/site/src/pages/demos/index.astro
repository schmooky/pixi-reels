---
import Base from '../../layouts/Base.astro';
import { DEMOS } from '../../content/demos.ts';
import { ArrowRight } from 'lucide-react';

const hueFor = (slug: string): number => {
  let h = 0;
  for (const c of slug) h = (h * 31 + c.charCodeAt(0)) % 360;
  return h;
};
---
<Base title="Demos · pixi-reels" description="Live mechanic sandboxes with cheats.">
  <section class="border-b border-border/60 py-16">
    <div class="container max-w-3xl text-center">
      <div class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary">
        Mechanics catalog
      </div>
      <h1 class="mt-4 text-balance text-4xl font-semibold tracking-tight sm:text-5xl">
        Mechanic sandboxes, <span class="gradient-text">any outcome on tap.</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-muted-foreground">
        Each demo is a live sandbox with headless symbols — runs anywhere.
        Toggle a cheat on the right, press SPIN, the advertised outcome lands
        every time.
      </p>
    </div>
  </section>

  <section class="py-14">
    <div class="container">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {DEMOS.map((d) => (
          <a
            href={`/demos/${d.slug}/`}
            class="group overflow-hidden rounded-xl border border-border bg-card transition-all hover:border-primary/40 hover:-translate-y-0.5"
          >
            <div
              class="relative flex h-32 items-center justify-center overflow-hidden"
              style={`background: linear-gradient(135deg, hsl(${hueFor(d.slug)}, 70%, 38%), hsl(${hueFor(d.slug + 'x')}, 70%, 22%));`}
            >
              <div class="absolute inset-0 opacity-30" style="background-image: repeating-linear-gradient(90deg, transparent 0 22px, rgba(255,255,255,0.04) 22px 23px);"></div>
              <span class="relative text-3xl font-bold text-white/70">◆</span>
            </div>
            <div class="p-5">
              <div class="mb-2.5 flex flex-wrap gap-1.5">
                {d.tags.map((t) => (
                  <span class="rounded-full bg-secondary/70 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-muted-foreground">
                    {t}
                  </span>
                ))}
              </div>
              <h3 class="text-base font-semibold tracking-tight">{d.title}</h3>
              <p class="mt-1 font-mono text-[12px] text-accent/90">{d.subtitle}</p>
              <p class="mt-2 text-sm text-muted-foreground">{d.summary}</p>
              <ul class="mt-3 space-y-1 text-[12px] font-mono">
                {d.cheatHighlights.map((c) => (
                  <li class="flex items-center gap-1.5 text-muted-foreground/80">
                    <span class="text-primary">◆</span>{c}
                  </li>
                ))}
              </ul>
              <div class="mt-4 inline-flex items-center gap-1 text-xs font-medium text-foreground/60 transition-colors group-hover:text-foreground">
                Open demo <ArrowRight size={13} strokeWidth={2} />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
