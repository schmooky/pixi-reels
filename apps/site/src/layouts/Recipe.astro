---
import Base from './Base.astro';
import { ChevronLeft } from 'lucide-react';
import { articleLd, howToLd, breadcrumbLd, SITE } from '../lib/seo.ts';
import RealGameVideo from '../components/RealGameVideo.astro';

interface RealGameVideoFrontmatter {
  webm?: string;
  mp4?: string;
  caption: string;
}

interface Props {
  title?: string;
  description?: string;
  steps?: string[];
  apis?: string[];
  tags?: string[];
  realGameVideo?: RealGameVideoFrontmatter;
  frontmatter?: {
    title?: string;
    description?: string;
    steps?: string[];
    apis?: string[];
    tags?: string[];
    realGameVideo?: RealGameVideoFrontmatter;
  };
}
const props = Astro.props as Props;
const fm = props.frontmatter ?? {};
const title = props.title ?? fm.title ?? 'Recipe';
const description = props.description ?? fm.description ?? `${title}. step-by-step slot recipe built with pixi-reels.`;
const steps = props.steps ?? fm.steps ?? [];
const apis = props.apis ?? fm.apis ?? [];
const tags = props.tags ?? fm.tags ?? [];
const realGameVideo = props.realGameVideo ?? fm.realGameVideo;
const pathname = Astro.url.pathname;

const jsonLd = [
  articleLd({ title, description, path: pathname }),
  howToLd({
    name: title,
    description,
    path: pathname,
    steps: steps.map((s, i) => ({ name: `Step ${i + 1}`, text: s })),
  }),
  breadcrumbLd([
    { name: SITE.name, url: '/' },
    { name: 'Recipes', url: '/recipes/' },
    { name: title, url: pathname },
  ]),
];
---
<Base
  title={`${title} · ${SITE.name} recipe`}
  description={description}
  path={pathname}
  type="article"
  article={{ section: 'Recipes', tags }}
  jsonLd={jsonLd}
>
  <div class="container max-w-[880px] py-10 animate-fade-in">
    <header class="mb-6">
      <a href="/recipes/" class="mb-4 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">
        <ChevronLeft size={14} strokeWidth={2} />
        All recipes
      </a>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
      {description && <p class="mt-2 text-muted-foreground max-w-[620px]">{description}</p>}
    </header>

    {realGameVideo && (
      <div class="mb-4">
        <RealGameVideo
          webm={realGameVideo.webm}
          mp4={realGameVideo.mp4}
          caption={realGameVideo.caption}
        />
      </div>
    )}

    <article class="prose-docs">
      <slot />
    </article>
  </div>
</Base>
