---
import { PARTNERS } from '../content/partners.ts';

/**
 * "Studios shipping with pixi-reels" — landing-page logo strip.
 *
 * Reads from `content/partners.ts`. Each entry renders as a logo tile
 * with an optional outbound link. Designed to look right with anywhere
 * from 1 to ~12 entries: under 4 partners the row centers; above that
 * it auto-flows into multiple rows.
 *
 * No JS. logos are inline `<img>` tags rendering SVG. Hover lifts the
 * tile and lights the border in the brand orange.
 */
const partners = PARTNERS;
---

<section class="border-b border-border/60 py-20" aria-labelledby="partners-heading">
  <div class="container">
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-border/80 bg-card/60 px-3 py-1 text-[11px] font-mono uppercase tracking-[0.18em] text-muted-foreground backdrop-blur-sm">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
        Studios &amp; providers
      </div>
      <h2 id="partners-heading" class="text-balance text-3xl font-semibold tracking-tight sm:text-4xl">
        Shipping with <span class="gradient-text">pixi-reels</span>
      </h2>
      <p class="mt-3 text-muted-foreground">
        Game studios and providers building production slot titles on the engine.
      </p>
    </div>

    <ul class="mx-auto grid max-w-5xl grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5" role="list">
      {partners.map((p) => {
        const tile = (
          <div class="group flex h-24 items-center justify-center rounded-2xl border border-border/80 bg-card/60 px-4 transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:bg-card hover:shadow-lg hover:shadow-primary/10">
            <img
              src={p.logo}
              alt={`${p.name} logo`}
              loading="lazy"
              decoding="async"
              class="max-h-12 w-auto opacity-90 transition-opacity group-hover:opacity-100"
            />
          </div>
        );
        return (
          <li>
            {p.url
              ? (
                <a
                  href={p.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={p.blurb ?? `${p.name} website`}
                  class="block"
                >
                  {tile}
                </a>
              )
              : tile}
          </li>
        );
      })}
    </ul>

    <p class="mt-10 text-center text-sm text-muted-foreground">
      Shipping with pixi-reels?
      <a
        href="https://github.com/schmooky/pixi-reels/issues/new?labels=partner&template=partner.yml&title=Partner%3A+%5Bstudio+name%5D"
        class="font-medium text-foreground underline decoration-primary/40 underline-offset-4 transition-colors hover:text-primary hover:decoration-primary"
      >
        Add your studio to the list
      </a>
      .
    </p>
  </div>
</section>
