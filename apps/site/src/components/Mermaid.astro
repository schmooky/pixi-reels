---
/**
 * Mermaid diagram renderer with the pixi-reels site theme.
 *
 * Usage:
 *   <Mermaid chart={`
 *     flowchart LR
 *       Builder --> ReelSet
 *       ReelSet --> Reels
 *   `} />
 *
 * Renders client-side after page load. The init script is deduped via the
 * `data-mermaid-init` marker so multiple `<Mermaid />` instances on one page
 * only initialize mermaid once.
 *
 * Theme matches the site's CSS variables; colors are re-resolved and the
 * diagram re-rendered whenever the light/dark theme toggles.
 */

interface Props {
  chart: string;
  /** Optional caption rendered below the diagram. */
  caption?: string;
  /** Optional class on the wrapping <figure>. */
  class?: string;
}
const { chart, caption, class: className } = Astro.props as Props;

// Stable id so multiple charts on a page don't collide.
const id = `mermaid-${Math.random().toString(36).slice(2, 10)}`;
---
<figure class:list={['not-prose my-8 rounded-2xl border border-border bg-card p-6 overflow-x-auto', className]}>
  <pre class="mermaid" id={id} data-mermaid-source>{chart}</pre>
  {caption && <figcaption class="mt-3 text-sm text-muted-foreground text-center">{caption}</figcaption>}
</figure>

<script>
  // Read a site color token and return it in a form mermaid's color parser
  // (khroma) understands. The CSS vars are space-separated HSL triples
  // ("240 10% 3.9%"); khroma needs the comma form ("hsl(240, 10%, 3.9%)").
  function color(name: string, fallback: string): string {
    const v = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    if (!v) return fallback;
    const parts = v.split(/\s+/);
    return parts.length === 3 ? `hsl(${parts[0]}, ${parts[1]}, ${parts[2]})` : v;
  }

  // Full monochrome palette: node/actor/note fills use a surface token (not
  // --primary, which is ink in light / paper in dark), text uses --foreground,
  // and notes are muted instead of mermaid's default yellow.
  function themeVariables() {
    return {
      background: color('--card', '#ffffff'),
      primaryColor: color('--secondary', '#f4f4f5'),
      primaryTextColor: color('--foreground', '#0a0a0a'),
      primaryBorderColor: color('--border', '#e4e4e7'),
      secondaryColor: color('--muted', '#f4f4f5'),
      secondaryTextColor: color('--foreground', '#0a0a0a'),
      secondaryBorderColor: color('--border', '#e4e4e7'),
      tertiaryColor: color('--muted', '#f4f4f5'),
      tertiaryTextColor: color('--foreground', '#0a0a0a'),
      tertiaryBorderColor: color('--border', '#e4e4e7'),
      lineColor: color('--muted-foreground', '#71717a'),
      textColor: color('--foreground', '#0a0a0a'),
      mainBkg: color('--secondary', '#f4f4f5'),
      nodeBorder: color('--border', '#e4e4e7'),
      nodeTextColor: color('--foreground', '#0a0a0a'),
      clusterBkg: color('--muted', '#f4f4f5'),
      clusterBorder: color('--border', '#e4e4e7'),
      titleColor: color('--foreground', '#0a0a0a'),
      edgeLabelBackground: color('--card', '#ffffff'),
      // Sequence diagrams — these are what the timeline charts use.
      actorBkg: color('--secondary', '#f4f4f5'),
      actorBorder: color('--border', '#e4e4e7'),
      actorTextColor: color('--foreground', '#0a0a0a'),
      actorLineColor: color('--border', '#e4e4e7'),
      signalColor: color('--muted-foreground', '#71717a'),
      signalTextColor: color('--foreground', '#0a0a0a'),
      labelBoxBkgColor: color('--muted', '#f4f4f5'),
      labelBoxBorderColor: color('--border', '#e4e4e7'),
      labelTextColor: color('--foreground', '#0a0a0a'),
      loopTextColor: color('--foreground', '#0a0a0a'),
      noteBkgColor: color('--muted', '#f4f4f5'),
      noteTextColor: color('--foreground', '#0a0a0a'),
      noteBorderColor: color('--border', '#e4e4e7'),
      activationBkgColor: color('--secondary', '#f4f4f5'),
      activationBorderColor: color('--border', '#e4e4e7'),
      sequenceNumberColor: color('--background', '#ffffff'),
      fontFamily: 'Inter, system-ui, sans-serif',
      fontSize: '14px',
    };
  }

  // Cache each chart's original source so we can re-render on theme change
  // (after the first run, the <pre> holds the rendered SVG, not the source).
  const sources = new WeakMap<Element, string>();
  let mermaidLib: typeof import('mermaid').default | null = null;

  async function render() {
    const nodes = document.querySelectorAll('pre.mermaid');
    if (!nodes.length) return;
    if (!mermaidLib) mermaidLib = (await import('mermaid')).default;

    nodes.forEach((el) => {
      if (!sources.has(el)) sources.set(el, el.textContent ?? '');
      el.innerHTML = sources.get(el) ?? '';
      el.removeAttribute('data-processed');
    });

    mermaidLib.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      theme: 'base',
      themeVariables: themeVariables(),
      flowchart: { curve: 'basis', htmlLabels: true, padding: 16 },
      sequence: { actorMargin: 60, boxMargin: 8 },
    });
    await mermaidLib.run({ querySelector: 'pre.mermaid' });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => void render());
  } else {
    void render();
  }
  document.addEventListener('astro:page-load', () => void render());

  // Re-render when the .dark class on <html> flips (theme toggle), so the
  // diagram colors track the active theme instead of the load-time one.
  let isDark = document.documentElement.classList.contains('dark');
  new MutationObserver(() => {
    const next = document.documentElement.classList.contains('dark');
    if (next !== isDark) {
      isDark = next;
      void render();
    }
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<style>
  /* Smooth before the diagram swaps in. avoids the raw text flashing. */
  pre.mermaid[data-mermaid-source]:not(:has(svg)) {
    color: transparent;
    user-select: none;
  }
  pre.mermaid {
    text-align: center;
    background: transparent;
    padding: 0;
    margin: 0;
  }
  pre.mermaid svg {
    max-width: 100%;
    height: auto;
  }
</style>
