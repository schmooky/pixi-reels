{
  "name": "pixi-reels-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "pixi-reels monorepo — open-source slot machine reel engine for PixiJS v8.",
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm --filter pixi-reels build && pnpm --filter classic-spin build && pnpm --filter cascade-tumble build && pnpm --filter big-symbols build && pnpm --filter multiways build && pnpm --filter pyramid-cascade build",
    "build:all": "node scripts/build-all-publishable.mjs",
    "test": "pnpm check:lint && pnpm --filter pixi-reels test",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "pnpm --filter pixi-reels typecheck",
    "lint": "pnpm --filter pixi-reels lint",
    "check:no-fancy-unicode": "node scripts/check-no-fancy-unicode.mjs",
    "check:imports": "biome lint packages/pixi-reels/src",
    "check:lint": "pnpm check:no-fancy-unicode && pnpm check:imports",
    "commitlint": "commitlint --edit",
    "examples:dev:classic": "pnpm --filter classic-spin dev",
    "examples:dev:cascade": "pnpm --filter cascade-tumble dev",
    "examples:dev:bigsymbols": "pnpm --filter big-symbols dev",
    "examples:dev:multiways": "pnpm --filter multiways dev",
    "examples:dev:pyramid": "pnpm --filter pyramid-cascade dev",
    "examples:dev:sandbox": "pnpm --filter sandbox dev",
    "examples:build": "pnpm --filter './examples/*' build",
    "site:dev": "pnpm --filter @pixi-reels/site dev",
    "site:build": "pnpm --filter @pixi-reels/site build",
    "site:preview": "pnpm --filter @pixi-reels/site preview",
    "share-api:dev": "pnpm --filter @pixi-reels/share-api dev",
    "share-api:build": "pnpm --filter @pixi-reels/share-api build",
    "share-api:start": "pnpm --filter @pixi-reels/share-api start",
    "share-api:typecheck": "pnpm --filter @pixi-reels/share-api typecheck",
    "symbols:build": "pnpm --filter pixi-reels-symbol-gen build",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build:all && changeset publish",
    "snapshot": "node scripts/snapshot-release.mjs",
    "size": "node scripts/size-check.mjs",
    "size:check": "node scripts/size-check.mjs --check",
    "size:update": "node scripts/size-check.mjs --update",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,md,mdx,astro,yml,yaml,json}": [
      "node scripts/check-no-fancy-unicode.mjs"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
